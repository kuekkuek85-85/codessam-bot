# ─────────────────────────────────────────────────────────────
# 코드쌤봇 2.0 환경변수
# 이 값들이 없어도 앱은 "데모 모드"(브라우저 localStorage)로 동작합니다.
# 실제 수업(여러 기기 실시간 동기화)에는 Firebase 설정이 필요합니다.
# ─────────────────────────────────────────────────────────────

# Firebase (Realtime Database) — https://console.firebase.google.com
# 아래 값을 채우면 자동으로 Realtime Database 실시간 모드로 전환됩니다.
# databaseURL이 비어 있으면 데모(localStorage) 모드로 동작합니다.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Gemini API — https://aistudio.google.com/app/apikey
# 없으면 AI 힌트는 "더미 질문형 응답"으로 폴백됩니다(PRD 9.4).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
