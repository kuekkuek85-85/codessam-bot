{
  "//": "코드쌤봇 2.0 Realtime Database 보안 규칙.",
  "//1": "이 앱은 로그인이 없어 학생/교사 모두 인증 없이 접근합니다.",
  "//2": "수업 운영 동안에는 아래처럼 읽기/쓰기를 열어 둡니다(접속 코드로 분리).",
  "//3": "수업이 끝나면 콘솔에서 규칙을 닫거나(.read/.write를 false) 데이터를 삭제하세요.",
  "//4": "장기 운영 시에는 Firebase Auth(익명 로그인)로 전환하고 규칙을 좁히는 것을 권장합니다.",
  "rules": {
    "missions": {
      ".read": true,
      ".write": true,
      ".indexOn": ["sessionId"]
    },
    "students": {
      ".read": true,
      ".write": true,
      ".indexOn": ["sessionId"]
    },
    "attempts": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId"]
    },
    "attemptImages": {
      "//": "캡처 이미지(data URL)를 attempt 본문과 분리 저장 — 대시보드 재다운로드 방지",
      ".read": true,
      ".write": true
    },
    "messages": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId", "attemptId"]
    },
    "warnings": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId"]
    }
  }
}
