{
  "rules": {
    "missions": {
      ".read": true,
      ".write": true,
      ".indexOn": ["sessionId"]
    },
    "students": {
      ".read": true,
      ".write": true,
      ".indexOn": ["sessionId"]
    },
    "attempts": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId"]
    },
    "attemptImages": {
      ".read": true,
      ".write": true
    },
    "messages": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId", "attemptId"]
    },
    "warnings": {
      ".read": true,
      ".write": true,
      ".indexOn": ["studentId"]
    }
  }
}
